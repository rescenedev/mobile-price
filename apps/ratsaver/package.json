{
  "name": "ratsaver",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-static-data.mjs && next dev",
    "sync:data": "node scripts/sync-static-data.mjs",
    "build": "node scripts/sync-static-data.mjs && next build",
    "pages:build": "node scripts/sync-static-data.mjs && npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "pages:deploy": "wrangler pages deploy .vercel/output/static --project-name=ratsaver --branch=main",
    "deploy": "npm run pages:build && npm run pages:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:seed:gen": "node --experimental-loader ./scripts/gen-seed/alias-loader.mjs ./scripts/gen-seed/run.mjs",
    "perf:bench": "node scripts/perf-bench/run.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "better-auth": "^1.6.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.38.0",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "web-vitals": "^4.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260613.1",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.9",
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vercel": "^54.13.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.86.0"
  }
}
